  public void setProjectParameters(String mode, String path, String name)
  {
    this.strNeoloadProjectMode = mode
    this.strNeoloadProjectPath = path
    this.strNeoloadProjectName = name
  }

  public void setDebugLogging(boolean value)
  {
    this.semaphorDebug = value
  }

  public void setRecordingOptions(boolean protocolWebSocket, boolean protocolAdobeRTMP, boolean protocolHTTP2)
  {
    this.setRecordingOptionProtocolWebSocket(protocolWebSocket)
    this.setRecordingOptionProtocolAdobeRTMP(protocolAdobeRTMP)
    this.setRecordingOptionProtocolHTTP2(protocolHTTP2)
  }

  public void setRecordingOptionProtocolWebSocket(boolean value)
  {
    this.recordingProtocolWebSocket = value
  }

  public void setRecordingOptionProtocolAdobeRTMP(boolean value)
  {
    this.recordingProtocolAdobeRTMP = value
  }

  public void setRecordingOptionProtocolHTTP2(boolean value)
  {
    this.recordingProtocolHTTP2 = value
  }

  public void nodeEntered(TestRunEvent event) {
   this.performActions("nodeEntered", event)
  }

  public void nodeExited(TestRunEvent event) {
    this.performActions("nodeExited", event)
  }

  public void problemOccurred(TestRunEvent event) {
    this.performActions("problemOccurred", event)
  }

  public void runStarted(TestRunEvent event) {
    this.performActions("runStarted", event)
  }

  public void runStopped(TestRunEvent event) {
    this.performActions("runStopped", event)
  }

  protected DesignAPIClient getClient()
  {
    if(null == this.xClient)
    {
      if(this.strAPIKey?.length() &gt; 0)
        this.xClient = DesignAPIClientFactory.newClient(this.xUrl.toString(), this.strAPIKey)
      else
        this.xClient = DesignAPIClientFactory.newClient(this.xUrl.toString())
    }
    return this.xClient
  }

  /**
   *  \brief    Mit dieser Methode kann ein NeoLoad-Projekt angelegt werden.
   *
   *  Mit dieser Methode wird ein NeoLoad-Projekt angelegt, sofern der Dateiname
   *  und das Verzeichnis gültig ist.
   *
   *  \param    projectName             In dem Parameter ist der Name des
   *                                    Projekts anzugeben.
   *  \param    directoryPath           In dem Parameter kann optional ein
   *                                    Verzeichnis übergeben werden, in dem das
   *                                    Projekt angelegt werden soll.&lt;br/&gt;
   *                                    Wird in diesem Parameter der Wert
   *                                    &lt;code&gt;null&lt;/code&gt; übergeben, dann wird
   *                                    das Projekt in dem Standardverzeichnis
   *                                    aus den Einstellungen von NeoLoad
   *                                    angelegt.
   *  \param    overwrite               In dem Parameter wird entschieden, ob
   *                                    ein bereits vorhandenes Projekt
   *                                    überschrieben werden soll oder nicht.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   */
  public void createProject(String projectName, String directoryPath, boolean overwrite) throws Exception
  {
    CreateProjectParamsBuilder params = new CreateProjectParamsBuilder()
                                                      .name(projectName)
                                                      .overwrite(overwrite);
    if(null != directoryPath)
      params = params.directoryPath(directoryPath);

    this.getClient().createProject(params.build());
    this.semaphorOpenProject = true
  }

  /**
   *  \brief    Methode zum Öffnen eines NeoLoad-Projekts.
   *
   *  Mit dieser Methode wird ein NeoLoad-Projekt geöffnet, das bereits
   *  existiert.
   *
   *  \param    filePath                In dem Parameter muss der voll
   *                                    qualifizierte Pfad zur .nlp-Datei
   *                                    übergeben werden, damit das
   *                                    entsprechende Projekt geöffnet werden
   *                                    kann.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   */
  public void openProject(String filePath) throws Exception
  {
    this.getClient().openProject( new OpenProjectParamsBuilder().filePath(filePath)
                                                                  .build()            );
    this.semaphorOpenProject = true
  }

  /**
   *  \brief    Methode setzt den Hauptcontainer für die Aufnahme.
   *
   *  In einem User Path gibt es die drei Hauptcontainer Init, Actions und
   *  End. Mit dieser Methode kann der Aufrufer den Hauptcontainer bestimmen,
   *  in dem die folgenden Requests aufgenommen werden sollen.
   *
   *  \param    baseContainer           In diesem Parameter ist der Hauptcontainer
   *                                    zu übergeben, in dem die folgenden
   *                                    Requests aufgenommen werden sollen.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   *
   */
  public void setBaseContainer(BaseContainer baseContainer) throws Exception
  {
    this.getClient().setBaseContainer(new SetBaseContainerParams(baseContainer));
  }

  /**
   *  \brief    Methode zum Start einer Aufnahme.
   *
   *  Mit dieser Methode wird eine Aufzeichnung in Proxy-Modus gestartet. Die
   *  Methode kommt auch erst zurück, wenn die Aufzeichnung gestartet ist.
   *
   *  \note     Die Methode unterstützt ausschließlich den Proxy-Modus. Der
   *            Tunnel-Modus kann über das Design API von NeoLoad nicht
   *            angesprochen werden.
   *
   *  \param    userPath                In dem Parameter ist der Name des
   *                                    UserPath zu übergeben, unter dem die
   *                                    Aufnahme angelegt werden soll.

   *                                    Falls in dem Parameter &lt;code&gt;null&lt;/code&gt;
   *                                    übergeben wird, wird die Bezeichnung
   *                                    &lt;code&gt;UserPath&lt;/code&gt; verwendet.
   *  \param    baseContainer           In dem Parameter kann festgelegt werden,
   *                                    in welchem der drei Hauptcontainer die
   *                                    Aufnahme gespeichert werden soll. Zur
   *                                    Auswahl stehen Init, Actions oder End.

   *                                    Wenn in dem Parameter &lt;code&gt;null&lt;/code&gt;
   *                                    übergeben wird, wird per Default der
   *                                    Container &lt;code&gt;Actions&lt;/code&gt; verwendet.
   *  \param    protocolWebSocket       In dem Parameter wird definiert, ob bei
   *                                    der Aufnahme das Protokoll WebSocket
   *                                    aktiv sein soll.

   *                                    Der Defaultwert von Seiten NeoLoad ist
   *                                    &lt;code&gt;true&lt;/code&gt;.
   *  \param    protocolAdobeRTMP       In dem Parameter wird definiert, ob bei
   *                                    der Aufnahme das Protokoll AdobeRTMP
   *                                    aktiv sein soll.

   *                                    Der Defaultwert von Seiten NeoLoad ist
   *                                    &lt;code&gt;false&lt;/code&gt;.
   *  \param    protocolHTTP2           In dem Parameter wird definiert, ob bei
   *                                    der Aufnahme das Protokoll HTTP2
   *                                    aktiv sein soll.

   *                                    Der Defaultwert von Seiten NeoLoad ist
   *                                    &lt;code&gt;true&lt;/code&gt;.
   *  \param    userAgent               In dem Parameter kann Aufrufer optional
   *                                    einen String übergeben, der für den
   *                                    User Agent steht.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   */
  public void startRecording( String userPath,
                              BaseContainer baseContainer,
                              boolean protocolWebSocket,
                              boolean protocolAdobeRTMP,
                              boolean protocolHTTP2,
                              String userAgent) throws Exception
  {
    StartRecordingBuilder builder = new StartRecordingBuilder();

    if(null != userPath)
      builder = builder.virtualUser(userPath);
    if(null != baseContainer)
      builder = builder.recordInStep(baseContainer);
    if(null != userAgent)
      builder = builder.userAgent(userAgent);

    this.getClient().startRecording( builder.isWebSocketProtocol(protocolWebSocket)
                                              .isAdobeRTMPProtocol(protocolAdobeRTMP)
                                              .isHTTP2Protocol(protocolHTTP2)
                                              .build());
  }

  /**
   *  \brief    Die Methode stoppt die Aufnahme.
   *
   *  Mit dieser Methode kann eine laufende Aufnahme gestoppt werden und es wird
   *  der Post-Recording-Wizard durchlaufen.
   *
   *  \note     Da es in dem Design API keinen gesichterten Status gibt, mit der
   *            eine laufende Aufnahme signalisiert, wird das Kommando ohne
   *            Vorprüfung abgesetzt. Sollte z.B. keine Aufnahme laufen, dann
   *            wird diese Methode eine Exception werfen, die von NeoLoad
   *            kommt.
   *
   *  \param    frameworkParameterSearch  In dem Parameter ist anzugeben, ob auf
   *                                    die Aufnahme die Framework-Parameter
   *                                    angewendet werden sollen. Dadurch werden
   *                                    bestimmte Requests mit variablen
   *                                    Ausdrücken versehen.

   *                                    Diese Einstellung ist mit Vorsicht zu
   *                                    verwenden, da die Framework-Parameter
   *                                    verwendet werden, die in der lokalen
   *                                    NeoLoad-Installation hinterlegt sind.
   *                                    Diese können von den Standard-Einstellungen
   *                                    stark abweichen und von daher sollte
   *                                    im Zweifel der Parameter auf
   *                                    &lt;code&gt;false&lt;/code&gt; gesetzt werden.
   *  \param    genericParameterSearch  Mit dem Parameter kann im
   *                                    Post-Recording-Process nach dynamischen
   *                                    Parametern gesucht werden.

   *                                    In der Regel ist hier der Wert
   *                                    &lt;code&gt;false&lt;/code&gt; zu setzen, da es
   *                                    sicherer ist, eine Aufnahme später
   *                                    manuell nachzubearbeiten.
   *  \param    updateUserPathParams    In dem Parameter lassen sich
   *                                    Einstellungen für ein mögliches User
   *                                    Path Update übergeben. Diese Option
   *                                    ist dann von Interesse, wenn eine
   *                                    Aufnahme für einen User Path erfolgen
   *                                    soll, der bereits besteht. In diesem
   *                                    Fall lassen sich bestehendes Skript und
   *                                    neue Aufnahme zusammenführen.

   *                                    Wenn dieses nicht gewünscht ist, dann
   *                                    ist in dem Parameter der Wert
   *                                    &lt;code&gt;null&lt;/code&gt; zu übergeben.
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   */
  public void stopRecording(  boolean               frameworkParameterSearch,
                              boolean               genericParameterSearch,
                              UpdateUserPathParams  updateUserPathParams        ) throws Exception
  {
    StopRecordingBuilder builder = new StopRecordingBuilder();

    if(null != updateUserPathParams)
      builder = builder.updateParams(updateUserPathParams);

    this.getClient().stopRecording(  builder.frameworkParameterSearch(frameworkParameterSearch)
                                              .genericParameterSearch(genericParameterSearch)
                                              .build()                                              );
  }

  /**
   *  \brief    Mit der Methode kann während einer Aufnahme eine neue
   *            Transaktion erstellt werden.
   *
   *  Transaktionen dienen in einem User Path zur Gliederung der Requests.
   *  Wenn eine Transaktion definert wird, dann werden die folgenden Requests
   *  unterhalb dieser Transaktion angeordnet.
   *
   *  Der Name einer Transaktion muss innerhalb eines User Path eindeutig sein.
   *  Sollte ein Name übergeben werden, der bereits existiert, dann ergänzt
   *  NeoLoad ein Suffix aus Unterstrich und Zahl, um den Namen eindeutig
   *  zu machen.
   *
   *  \note     Innerhalb des Listeners wird diese Methode von nodeEntered(TestRunEvent)
   *            aufgerufen, da in Abhängigkeit der von Testsequenzen und
   *            Testfallknoten automatisch Transaktionen gesetzt werden.
   *            Die Namen dieser Transaktion sind generiert auf Basis der
   *            entsprechenden Knoten.
   *
   *  \param    name                    In dem Parameter ist der Name für die
   *                                    Transaktion zu übergeben.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   *
   */
  public void setContainer(String name) throws Exception
  {
    this.getClient().setContainer(new SetContainerParams(name))
  }

  /**
   *  \brief    Methode zum Speichern des aktuell geöffneten Projekts.
   *
   *  Mit dieser Methode kann das aktuelle Projekt gespeichert werden. Es wird
   *  unter dem Pfad gespeichert, unter dem es angelegt bzw. geöffnet wurde.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   */
  public void saveProject() throws Exception
  {
    this.getClient().saveProject();
  }

  /**
   *  \brief    Methode zum Schließen eines Projekts
   *
   *  Mit dieser Methode kann das aktuell geöffnete Projekt geschlossen werden.
   *
   *  \param    save                    Mit dem Parameter kann der Aufrufer
   *                                    steuern, ob das aktuelle Projekt vor
   *                                    dem Schließen gespeichert werden soll.
   *                                    &lt;br/&gt; Wenn der Wert &lt;code&gt;true&lt;/code&gt;
   *                                    übergeben wird, dann wird erst nach dem
   *                                    Speichern des Projekts dieses
   *                                    geschlossen, damit keine Änderungen
   *                                    verloren gehen.
   *  \param    forceStop               Mit dem Parameter kann der Aufrufer ein
   *                                    Schließen des Projekts erzwingen. Das
   *                                    bedeutet, dass eventuelle Tests oder
   *                                    Aufnahmen gestoppt werden.&lt;br/&gt;
   *                                    Der Defaultwert in Bezug auf das API
   *                                    ist &lt;code&gt;false&lt;/code&gt;.
   *
   *  \throws   Exception               Für den Fall, dass eine Verarbeitung
   *                                    nicht möglich ist, wird eine Exception
   *                                    weitergereicht, die vom Aufrufer zu
   *                                    behandeln ist, da innerhalb dieser
   *                                    Methode keine Maßnahme ergiffen werden
   *                                    kann, die in jedem Fall geeignet ist.
   */
  public void closeProject(boolean save, boolean forceStop) throws Exception
  {
    this.getClient().closeProject(  new CloseProjectParamsBuilder()
                                                      .forceStop(forceStop)
                                                      .save(save)
                                                      .build()          )
    this.semaphorOpenProject = false
  }

}
