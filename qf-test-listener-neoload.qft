                // Rule R81 &lt;----
            }

        // Condition B02/05: NeoloadStatus / BUSY / NeoLoad ist durch eine Aufzeichnung oder einen Dialog blockiert
        } else if ( Status.BUSY == status ) {

            // Condition B10/01: Counter: waitForReady / inside / Wartezeit ist noch nicht abgelaufen
