    <Action uId="17679779842736276">
      <Title language="German" value="Stack: Transaction"/>
      <ActionOccurrences>
        <ActionOccurrence uId="17679780248886814">
          <Symbol language="German" value="Reset"/>
          <Title language="German" value="alle Elemente werden gelöscht"/>
          <SourceCode codeLanguage="Groovy" sourceCodeType="StmtSeq" value="this.containerStack.clear()"/>
        </ActionOccurrence>
        <ActionOccurrence uId="17679780554186818">
          <Symbol language="German" value="Push"/>
          <Title language="German" value="ein Element wird in den Stack eingefügt"/>
          <SourceCode codeLanguage="Groovy" sourceCodeType="StmtSeq" value="if(null != event.getNode().getName()) this.containerStack.push(&quot;&quot;&quot;${event.getNode().getName().trim()}&quot;&quot;&quot;)"/>
        </ActionOccurrence>
        <ActionOccurrence uId="17679780955006821">
          <Symbol language="German" value="Pop"/>
          <Title language="German" value="ein Element wird entfernt"/>
          <SourceCode codeLanguage="Groovy" sourceCodeType="StmtSeq" value="if(null != event.getNode().getName())&lt;br/&gt;  if(1 == this.containerStack.search(&quot;&quot;&quot;${event.getNode().getName().trim()}&quot;&quot;&quot;))&lt;br/&gt;    this.containerStack.pop()"/>
        </ActionOccurrence>
      </ActionOccurrences>
    </Action>
    <Action uId="17679451508598528">
      <Title language="German" value="Counter: waitForReady"/>
      <ActionOccurrences>
        <ActionOccurrence uId="17679451836818845">
          <Symbol language="German" value="Reset"/>
          <Title language="German" value="Zurücksetzen auf 0"/>
          <SourceCode codeLanguage="Groovy" sourceCodeType="StmtSeq" value="this.counterWaitForReady = 0"/>
        </ActionOccurrence>
        <ActionOccurrence uId="17679451891798849">
          <Symbol language="German" value="+1"/>
          <Title language="German" value="Zähler um 1 erhöhen"/>
          <SourceCode codeLanguage="Groovy" sourceCodeType="StmtSeq" value="Thread.sleep(100)&lt;br/&gt;++this.counterWaitForReady"/>
        </ActionOccurrence>
      </ActionOccurrences>
    </Action>
