  <SourceCode codeLanguage="Groovy" sourceCodeType="Prolog" value="import java.io.IOException;&lt;br/&gt;import java.nio.file.Files&lt;br/&gt;import java.nio.file.Paths&lt;br/&gt;import java.net.MalformedURLException;&lt;br/&gt;import java.net.URISyntaxException;&lt;br/&gt;import java.net.URL;&lt;br/&gt;import java.security.GeneralSecurityException;&lt;br/&gt;import java.util.Arrays;&lt;br/&gt;import java.util.HashMap;&lt;br/&gt;import java.util.List;&lt;br/&gt;import java.util.Vector;&lt;br/&gt;import java.util.Stack;&lt;br/&gt;&lt;br/&gt;import de.qfs.apps.qftest.extensions.qftest.TestRunListener;&lt;br/&gt;import de.qfs.apps.qftest.extensions.qftest.TestRunEvent;&lt;br/&gt;import de.qfs.apps.qftest.extensions.qftest.TestSuiteNode;&lt;br/&gt;import de.qfs.apps.qftest.run.AbstractRunContext;&lt;br/&gt;import de.qfs.apps.qftest.shared.exceptions.TestException;&lt;br/&gt;import de.qfs.apps.qftest.step.AbstractStep;&lt;br/&gt;&lt;br/&gt;import org.apache.olingo.odata2.api.exception.ODataException;&lt;br/&gt;&lt;br/&gt;import com.neotys.rest.design.client.DesignAPIClient;&lt;br/&gt;import com.neotys.rest.design.client.DesignAPIClientFactory;&lt;br/&gt;import com.neotys.rest.design.model.CloseProjectParams.CloseProjectParamsBuilder;&lt;br/&gt;import com.neotys.rest.design.model.ContainsUserPathParams.ContainsUserPathParamsBuilder;&lt;br/&gt;import com.neotys.rest.design.model.CreateProjectParams.CreateProjectParamsBuilder;&lt;br/&gt;import com.neotys.rest.design.model.IsProjectOpenParams.IsProjectOpenParamsBuilder;&lt;br/&gt;import com.neotys.rest.design.model.OpenProjectParams.OpenProjectParamsBuilder;&lt;br/&gt;import com.neotys.rest.design.model.RecorderSettings;&lt;br/&gt;import com.neotys.rest.design.model.RecordingStatus;&lt;br/&gt;import com.neotys.rest.design.model.SetBaseContainerParams;&lt;br/&gt;import com.neotys.rest.design.model.SetBaseContainerParams.BaseContainer;&lt;br/&gt;import com.neotys.rest.design.model.SetContainerParams;&lt;br/&gt;import com.neotys.rest.design.model.StartRecordingParams.StartRecordingBuilder;&lt;br/&gt;import com.neotys.rest.design.model.StopRecordingParams.StopRecordingBuilder;&lt;br/&gt;import com.neotys.rest.design.model.UpdateUserPathParams;&lt;br/&gt;import com.neotys.rest.error.NeotysAPIException;&lt;br/&gt;import com.neotys.rest.runtime.model.Status;&lt;br/&gt;&lt;br/&gt;//  Prüfung, ob bereits ein Listener des Typs registriert ist.&lt;br/&gt;try&lt;br/&gt;{&lt;br/&gt;  if(null != __NEOLOADRECORDINGLISTENER__)&lt;br/&gt;  { //  In diesem Fall wurde bereits ein Listner registriert, der zu löschen ist.&lt;br/&gt;    rc.removeTestRunListener(__NEOLOADRECORDINGLISTENER__)&lt;br/&gt;    __NEOLOADRECORDINGLISTENER__ = null&lt;br/&gt;  }&lt;br/&gt;}&lt;br/&gt;catch(Exception e) {  /* Keine Aktion erforderlich, da dieser Block beim ersten Aufruf erwartet wird. */ }&lt;br/&gt;&lt;br/&gt;//  Initialisierung und Registrierung einer neuen Instanz des Listeners&lt;br/&gt;__NEOLOADRECORDINGLISTENER__ = new NeoloadRecordingListener(rc.context, rc.getStr(&quot;strNeoloadController&quot;), rc.getInt(&quot;iPort&quot;), rc.getStr(&quot;strAPIKey&quot;));&lt;br/&gt;__NEOLOADRECORDINGLISTENER__.setProjectParameters(rc.getStr(&quot;strNeoloadProjectMode&quot;), rc.getStr(&quot;strNeoloadProjectPath&quot;), rc.getStr(&quot;strNeoloadProjectName&quot;))&lt;br/&gt;__NEOLOADRECORDINGLISTENER__.setRecordingOptions(rc.getBool(&quot;bProtocolWebSocket&quot;).booleanValue(), rc.getBool(&quot;bProtocolAdobeRTMP&quot;).booleanValue(), rc.getBool(&quot;bProtocolHTTP2&quot;).booleanValue())&lt;br/&gt;__NEOLOADRECORDINGLISTENER__.setDebugLogging(rc.expand(&quot;\${default:debug:false}&quot;).equals(&quot;true&quot;))&lt;br/&gt;rc.addTestRunListener(__NEOLOADRECORDINGLISTENER__);&lt;br/&gt;&lt;br/&gt;public class NeoloadRecordingListener implements TestRunListener&lt;br/&gt;{&lt;br/&gt;  private int borderWaitForReady = 50&lt;br/&gt;  protected AbstractRunContext rc&lt;br/&gt;  protected URL xUrl = null&lt;br/&gt;  private String strAPIKey&lt;br/&gt;  private DesignAPIClient xClient = null&lt;br/&gt;  private String strNeoloadProjectMode = &quot;CURRENT&quot;&lt;br/&gt;  private String strNeoloadProjectPath = &quot;&quot;&lt;br/&gt;  private String strNeoloadProjectName = &quot;&quot;&lt;br/&gt;  private boolean semaphorRecordingReady = false&lt;br/&gt;  private boolean semaphorOpenProject = false&lt;br/&gt;  private boolean recordingProtocolWebSocket = true&lt;br/&gt;  private boolean recordingProtocolAdobeRTMP = false&lt;br/&gt;  private boolean recordingProtocolHTTP2 = true&lt;br/&gt;  private Stack&lt;String&gt; containerStack&lt;br/&gt;  private int counterWaitForReady = 0&lt;br/&gt;&lt;br/&gt;  protected boolean semaphorDebug = false&lt;br/&gt;&lt;br/&gt;  public NeoloadRecordingListener(AbstractRunContext rc, String neoloadHost, int neoloadPort, String apiKey)&lt;br/&gt;  {&lt;br/&gt;        this.rc = rc&lt;br/&gt;        this.strAPIKey = apiKey&lt;br/&gt;        this.xUrl = new URL(&quot;http&quot;, neoloadHost, neoloadPort, &quot;/Design/v1/Service.svc/&quot;)&lt;br/&gt;        this.containerStack = []&lt;br/&gt;        this.semaphorRecordingReady = true&lt;br/&gt;    }&lt;br/&gt;&lt;br/&gt;    public void performActions(String eventProcedure, TestRunEvent event) {&lt;br/&gt;        Status status&lt;br/&gt;        RecordingStatus recordingStatus"/>
  <SourceCode codeLanguage="Groovy" sourceCodeType="Epilog" value="  }&lt;br/&gt;&lt;br/&gt;  public void setProjectParameters(String mode, String path, String name)&lt;br/&gt;  {&lt;br/&gt;    this.strNeoloadProjectMode = mode&lt;br/&gt;    this.strNeoloadProjectPath = path&lt;br/&gt;    this.strNeoloadProjectName = name&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void setDebugLogging(boolean value)&lt;br/&gt;  {&lt;br/&gt;    this.semaphorDebug = value&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void setRecordingOptions(boolean protocolWebSocket, boolean protocolAdobeRTMP, boolean protocolHTTP2)&lt;br/&gt;  {&lt;br/&gt;    this.setRecordingOptionProtocolWebSocket(protocolWebSocket)&lt;br/&gt;    this.setRecordingOptionProtocolAdobeRTMP(protocolAdobeRTMP)&lt;br/&gt;    this.setRecordingOptionProtocolHTTP2(protocolHTTP2)&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void setRecordingOptionProtocolWebSocket(boolean value)&lt;br/&gt;  {&lt;br/&gt;    this.recordingProtocolWebSocket = value&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void setRecordingOptionProtocolAdobeRTMP(boolean value)&lt;br/&gt;  {&lt;br/&gt;    this.recordingProtocolAdobeRTMP = value&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void setRecordingOptionProtocolHTTP2(boolean value)&lt;br/&gt;  {&lt;br/&gt;    this.recordingProtocolHTTP2 = value&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void nodeEntered(TestRunEvent event) {&lt;br/&gt;   this.performActions(&quot;nodeEntered&quot;, event)&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void nodeExited(TestRunEvent event) {&lt;br/&gt;    this.performActions(&quot;nodeExited&quot;, event)&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void problemOccurred(TestRunEvent event) {&lt;br/&gt;    this.performActions(&quot;problemOccurred&quot;, event)&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void runStarted(TestRunEvent event) {&lt;br/&gt;    this.performActions(&quot;runStarted&quot;, event)&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  public void runStopped(TestRunEvent event) {&lt;br/&gt;    this.performActions(&quot;runStopped&quot;, event)&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  protected DesignAPIClient getClient()&lt;br/&gt;  {&lt;br/&gt;    if(null == this.xClient)&lt;br/&gt;    {&lt;br/&gt;      if(this.strAPIKey?.length() &gt; 0)&lt;br/&gt;        this.xClient = DesignAPIClientFactory.newClient(this.xUrl.toString(), this.strAPIKey)&lt;br/&gt;      else&lt;br/&gt;        this.xClient = DesignAPIClientFactory.newClient(this.xUrl.toString())&lt;br/&gt;    }&lt;br/&gt;    return this.xClient&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Mit dieser Methode kann ein NeoLoad-Projekt angelegt werden.&lt;br/&gt;   *&lt;br/&gt;   *  Mit dieser Methode wird ein NeoLoad-Projekt angelegt, sofern der Dateiname&lt;br/&gt;   *  und das Verzeichnis gültig ist.&lt;br/&gt;   *&lt;br/&gt;   *  \param    projectName             In dem Parameter ist der Name des&lt;br/&gt;   *                                    Projekts anzugeben.&lt;br/&gt;   *  \param    directoryPath           In dem Parameter kann optional ein&lt;br/&gt;   *                                    Verzeichnis übergeben werden, in dem das&lt;br/&gt;   *                                    Projekt angelegt werden soll.&lt;br/&gt;&lt;br/&gt;   *                                    Wird in diesem Parameter der Wert&lt;br/&gt;   *                                    &lt;code&gt;null&lt;/code&gt; übergeben, dann wird&lt;br/&gt;   *                                    das Projekt in dem Standardverzeichnis&lt;br/&gt;   *                                    aus den Einstellungen von NeoLoad&lt;br/&gt;   *                                    angelegt.&lt;br/&gt;   *  \param    overwrite               In dem Parameter wird entschieden, ob&lt;br/&gt;   *                                    ein bereits vorhandenes Projekt&lt;br/&gt;   *                                    überschrieben werden soll oder nicht.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   */&lt;br/&gt;  public void createProject(String projectName, String directoryPath, boolean overwrite) throws Exception&lt;br/&gt;  {&lt;br/&gt;    CreateProjectParamsBuilder params = new CreateProjectParamsBuilder()&lt;br/&gt;                                                      .name(projectName)&lt;br/&gt;                                                      .overwrite(overwrite);&lt;br/&gt;    if(null != directoryPath)&lt;br/&gt;      params = params.directoryPath(directoryPath);&lt;br/&gt;&lt;br/&gt;    this.getClient().createProject(params.build());&lt;br/&gt;    this.semaphorOpenProject = true&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Methode zum Öffnen eines NeoLoad-Projekts.&lt;br/&gt;   *&lt;br/&gt;   *  Mit dieser Methode wird ein NeoLoad-Projekt geöffnet, das bereits&lt;br/&gt;   *  existiert.&lt;br/&gt;   *&lt;br/&gt;   *  \param    filePath                In dem Parameter muss der voll&lt;br/&gt;   *                                    qualifizierte Pfad zur .nlp-Datei&lt;br/&gt;   *                                    übergeben werden, damit das&lt;br/&gt;   *                                    entsprechende Projekt geöffnet werden&lt;br/&gt;   *                                    kann.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   */&lt;br/&gt;  public void openProject(String filePath) throws Exception&lt;br/&gt;  {&lt;br/&gt;    this.getClient().openProject( new OpenProjectParamsBuilder().filePath(filePath)&lt;br/&gt;                                                                  .build()            );&lt;br/&gt;    this.semaphorOpenProject = true&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Methode setzt den Hauptcontainer für die Aufnahme.&lt;br/&gt;   *&lt;br/&gt;   *  In einem User Path gibt es die drei Hauptcontainer Init, Actions und&lt;br/&gt;   *  End. Mit dieser Methode kann der Aufrufer den Hauptcontainer bestimmen,&lt;br/&gt;   *  in dem die folgenden Requests aufgenommen werden sollen.&lt;br/&gt;   *&lt;br/&gt;   *  \param    baseContainer           In diesem Parameter ist der Hauptcontainer&lt;br/&gt;   *                                    zu übergeben, in dem die folgenden&lt;br/&gt;   *                                    Requests aufgenommen werden sollen.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   *&lt;br/&gt;   */&lt;br/&gt;  public void setBaseContainer(BaseContainer baseContainer) throws Exception&lt;br/&gt;  {&lt;br/&gt;    this.getClient().setBaseContainer(new SetBaseContainerParams(baseContainer));&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Methode zum Start einer Aufnahme.&lt;br/&gt;   *&lt;br/&gt;   *  Mit dieser Methode wird eine Aufzeichnung in Proxy-Modus gestartet. Die&lt;br/&gt;   *  Methode kommt auch erst zurück, wenn die Aufzeichnung gestartet ist.&lt;br/&gt;   *&lt;br/&gt;   *  \note     Die Methode unterstützt ausschließlich den Proxy-Modus. Der&lt;br/&gt;   *            Tunnel-Modus kann über das Design API von NeoLoad nicht&lt;br/&gt;   *            angesprochen werden.&lt;br/&gt;   *&lt;br/&gt;   *  \param    userPath                In dem Parameter ist der Name des&lt;br/&gt;   *                                    UserPath zu übergeben, unter dem die&lt;br/&gt;   *                                    Aufnahme angelegt werden soll.&lt;br/&gt;&lt;br/&gt;   *                                    Falls in dem Parameter &lt;code&gt;null&lt;/code&gt;&lt;br/&gt;   *                                    übergeben wird, wird die Bezeichnung&lt;br/&gt;   *                                    &lt;code&gt;UserPath&lt;/code&gt; verwendet.&lt;br/&gt;   *  \param    baseContainer           In dem Parameter kann festgelegt werden,&lt;br/&gt;   *                                    in welchem der drei Hauptcontainer die&lt;br/&gt;   *                                    Aufnahme gespeichert werden soll. Zur&lt;br/&gt;   *                                    Auswahl stehen Init, Actions oder End.&lt;br/&gt;&lt;br/&gt;   *                                    Wenn in dem Parameter &lt;code&gt;null&lt;/code&gt;&lt;br/&gt;   *                                    übergeben wird, wird per Default der&lt;br/&gt;   *                                    Container &lt;code&gt;Actions&lt;/code&gt; verwendet.&lt;br/&gt;   *  \param    protocolWebSocket       In dem Parameter wird definiert, ob bei&lt;br/&gt;   *                                    der Aufnahme das Protokoll WebSocket&lt;br/&gt;   *                                    aktiv sein soll.&lt;br/&gt;&lt;br/&gt;   *                                    Der Defaultwert von Seiten NeoLoad ist&lt;br/&gt;   *                                    &lt;code&gt;true&lt;/code&gt;.&lt;br/&gt;   *  \param    protocolAdobeRTMP       In dem Parameter wird definiert, ob bei&lt;br/&gt;   *                                    der Aufnahme das Protokoll AdobeRTMP&lt;br/&gt;   *                                    aktiv sein soll.&lt;br/&gt;&lt;br/&gt;   *                                    Der Defaultwert von Seiten NeoLoad ist&lt;br/&gt;   *                                    &lt;code&gt;false&lt;/code&gt;.&lt;br/&gt;   *  \param    protocolHTTP2           In dem Parameter wird definiert, ob bei&lt;br/&gt;   *                                    der Aufnahme das Protokoll HTTP2&lt;br/&gt;   *                                    aktiv sein soll.&lt;br/&gt;&lt;br/&gt;   *                                    Der Defaultwert von Seiten NeoLoad ist&lt;br/&gt;   *                                    &lt;code&gt;true&lt;/code&gt;.&lt;br/&gt;   *  \param    userAgent               In dem Parameter kann Aufrufer optional&lt;br/&gt;   *                                    einen String übergeben, der für den&lt;br/&gt;   *                                    User Agent steht.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   */&lt;br/&gt;  public void startRecording( String userPath,&lt;br/&gt;                              BaseContainer baseContainer,&lt;br/&gt;                              boolean protocolWebSocket,&lt;br/&gt;                              boolean protocolAdobeRTMP,&lt;br/&gt;                              boolean protocolHTTP2,&lt;br/&gt;                              String userAgent) throws Exception&lt;br/&gt;  {&lt;br/&gt;    StartRecordingBuilder builder = new StartRecordingBuilder();&lt;br/&gt;&lt;br/&gt;    if(null != userPath)&lt;br/&gt;      builder = builder.virtualUser(userPath);&lt;br/&gt;    if(null != baseContainer)&lt;br/&gt;      builder = builder.recordInStep(baseContainer);&lt;br/&gt;    if(null != userAgent)&lt;br/&gt;      builder = builder.userAgent(userAgent);&lt;br/&gt;&lt;br/&gt;    this.getClient().startRecording( builder.isWebSocketProtocol(protocolWebSocket)&lt;br/&gt;                                              .isAdobeRTMPProtocol(protocolAdobeRTMP)&lt;br/&gt;                                              .isHTTP2Protocol(protocolHTTP2)&lt;br/&gt;                                              .build());&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Die Methode stoppt die Aufnahme.&lt;br/&gt;   *&lt;br/&gt;   *  Mit dieser Methode kann eine laufende Aufnahme gestoppt werden und es wird&lt;br/&gt;   *  der Post-Recording-Wizard durchlaufen.&lt;br/&gt;   *&lt;br/&gt;   *  \note     Da es in dem Design API keinen gesichterten Status gibt, mit der&lt;br/&gt;   *            eine laufende Aufnahme signalisiert, wird das Kommando ohne&lt;br/&gt;   *            Vorprüfung abgesetzt. Sollte z.B. keine Aufnahme laufen, dann&lt;br/&gt;   *            wird diese Methode eine Exception werfen, die von NeoLoad&lt;br/&gt;   *            kommt.&lt;br/&gt;   *&lt;br/&gt;   *  \param    frameworkParameterSearch  In dem Parameter ist anzugeben, ob auf&lt;br/&gt;   *                                    die Aufnahme die Framework-Parameter&lt;br/&gt;   *                                    angewendet werden sollen. Dadurch werden&lt;br/&gt;   *                                    bestimmte Requests mit variablen&lt;br/&gt;   *                                    Ausdrücken versehen.&lt;br/&gt;&lt;br/&gt;   *                                    Diese Einstellung ist mit Vorsicht zu&lt;br/&gt;   *                                    verwenden, da die Framework-Parameter&lt;br/&gt;   *                                    verwendet werden, die in der lokalen&lt;br/&gt;   *                                    NeoLoad-Installation hinterlegt sind.&lt;br/&gt;   *                                    Diese können von den Standard-Einstellungen&lt;br/&gt;   *                                    stark abweichen und von daher sollte&lt;br/&gt;   *                                    im Zweifel der Parameter auf&lt;br/&gt;   *                                    &lt;code&gt;false&lt;/code&gt; gesetzt werden.&lt;br/&gt;   *  \param    genericParameterSearch  Mit dem Parameter kann im&lt;br/&gt;   *                                    Post-Recording-Process nach dynamischen&lt;br/&gt;   *                                    Parametern gesucht werden.&lt;br/&gt;&lt;br/&gt;   *                                    In der Regel ist hier der Wert&lt;br/&gt;   *                                    &lt;code&gt;false&lt;/code&gt; zu setzen, da es&lt;br/&gt;   *                                    sicherer ist, eine Aufnahme später&lt;br/&gt;   *                                    manuell nachzubearbeiten.&lt;br/&gt;   *  \param    updateUserPathParams    In dem Parameter lassen sich&lt;br/&gt;   *                                    Einstellungen für ein mögliches User&lt;br/&gt;   *                                    Path Update übergeben. Diese Option&lt;br/&gt;   *                                    ist dann von Interesse, wenn eine&lt;br/&gt;   *                                    Aufnahme für einen User Path erfolgen&lt;br/&gt;   *                                    soll, der bereits besteht. In diesem&lt;br/&gt;   *                                    Fall lassen sich bestehendes Skript und&lt;br/&gt;   *                                    neue Aufnahme zusammenführen.&lt;br/&gt;&lt;br/&gt;   *                                    Wenn dieses nicht gewünscht ist, dann&lt;br/&gt;   *                                    ist in dem Parameter der Wert&lt;br/&gt;   *                                    &lt;code&gt;null&lt;/code&gt; zu übergeben.&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   */&lt;br/&gt;  public void stopRecording(  boolean               frameworkParameterSearch,&lt;br/&gt;                              boolean               genericParameterSearch,&lt;br/&gt;                              UpdateUserPathParams  updateUserPathParams        ) throws Exception&lt;br/&gt;  {&lt;br/&gt;    StopRecordingBuilder builder = new StopRecordingBuilder();&lt;br/&gt;&lt;br/&gt;    if(null != updateUserPathParams)&lt;br/&gt;      builder = builder.updateParams(updateUserPathParams);&lt;br/&gt;&lt;br/&gt;    this.getClient().stopRecording(  builder.frameworkParameterSearch(frameworkParameterSearch)&lt;br/&gt;                                              .genericParameterSearch(genericParameterSearch)&lt;br/&gt;                                              .build()                                              );&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Mit der Methode kann während einer Aufnahme eine neue&lt;br/&gt;   *            Transaktion erstellt werden.&lt;br/&gt;   *&lt;br/&gt;   *  Transaktionen dienen in einem User Path zur Gliederung der Requests.&lt;br/&gt;   *  Wenn eine Transaktion definert wird, dann werden die folgenden Requests&lt;br/&gt;   *  unterhalb dieser Transaktion angeordnet.&lt;br/&gt;   *&lt;br/&gt;   *  Der Name einer Transaktion muss innerhalb eines User Path eindeutig sein.&lt;br/&gt;   *  Sollte ein Name übergeben werden, der bereits existiert, dann ergänzt&lt;br/&gt;   *  NeoLoad ein Suffix aus Unterstrich und Zahl, um den Namen eindeutig&lt;br/&gt;   *  zu machen.&lt;br/&gt;   *&lt;br/&gt;   *  \note     Innerhalb des Listeners wird diese Methode von nodeEntered(TestRunEvent)&lt;br/&gt;   *            aufgerufen, da in Abhängigkeit der von Testsequenzen und&lt;br/&gt;   *            Testfallknoten automatisch Transaktionen gesetzt werden.&lt;br/&gt;   *            Die Namen dieser Transaktion sind generiert auf Basis der&lt;br/&gt;   *            entsprechenden Knoten.&lt;br/&gt;   *&lt;br/&gt;   *  \param    name                    In dem Parameter ist der Name für die&lt;br/&gt;   *                                    Transaktion zu übergeben.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   *&lt;br/&gt;   */&lt;br/&gt;  public void setContainer(String name) throws Exception&lt;br/&gt;  {&lt;br/&gt;    this.getClient().setContainer(new SetContainerParams(name))&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Methode zum Speichern des aktuell geöffneten Projekts.&lt;br/&gt;   *&lt;br/&gt;   *  Mit dieser Methode kann das aktuelle Projekt gespeichert werden. Es wird&lt;br/&gt;   *  unter dem Pfad gespeichert, unter dem es angelegt bzw. geöffnet wurde.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   */&lt;br/&gt;  public void saveProject() throws Exception&lt;br/&gt;  {&lt;br/&gt;    this.getClient().saveProject();&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  /**&lt;br/&gt;   *  \brief    Methode zum Schließen eines Projekts&lt;br/&gt;   *&lt;br/&gt;   *  Mit dieser Methode kann das aktuell geöffnete Projekt geschlossen werden.&lt;br/&gt;   *&lt;br/&gt;   *  \param    save                    Mit dem Parameter kann der Aufrufer&lt;br/&gt;   *                                    steuern, ob das aktuelle Projekt vor&lt;br/&gt;   *                                    dem Schließen gespeichert werden soll.&lt;br/&gt;   *                                    &lt;br/&gt; Wenn der Wert &lt;code&gt;true&lt;/code&gt;&lt;br/&gt;   *                                    übergeben wird, dann wird erst nach dem&lt;br/&gt;   *                                    Speichern des Projekts dieses&lt;br/&gt;   *                                    geschlossen, damit keine Änderungen&lt;br/&gt;   *                                    verloren gehen.&lt;br/&gt;   *  \param    forceStop               Mit dem Parameter kann der Aufrufer ein&lt;br/&gt;   *                                    Schließen des Projekts erzwingen. Das&lt;br/&gt;   *                                    bedeutet, dass eventuelle Tests oder&lt;br/&gt;   *                                    Aufnahmen gestoppt werden.&lt;br/&gt;&lt;br/&gt;   *                                    Der Defaultwert in Bezug auf das API&lt;br/&gt;   *                                    ist &lt;code&gt;false&lt;/code&gt;.&lt;br/&gt;   *&lt;br/&gt;   *  \throws   Exception               Für den Fall, dass eine Verarbeitung&lt;br/&gt;   *                                    nicht möglich ist, wird eine Exception&lt;br/&gt;   *                                    weitergereicht, die vom Aufrufer zu&lt;br/&gt;   *                                    behandeln ist, da innerhalb dieser&lt;br/&gt;   *                                    Methode keine Maßnahme ergiffen werden&lt;br/&gt;   *                                    kann, die in jedem Fall geeignet ist.&lt;br/&gt;   */&lt;br/&gt;  public void closeProject(boolean save, boolean forceStop) throws Exception&lt;br/&gt;  {&lt;br/&gt;    this.getClient().closeProject(  new CloseProjectParamsBuilder()&lt;br/&gt;                                                      .forceStop(forceStop)&lt;br/&gt;                                                      .save(save)&lt;br/&gt;                                                      .build()          )&lt;br/&gt;    this.semaphorOpenProject = false&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;&lt;br/&gt;}"/>
  <SourceCode codeLanguage="Groovy" sourceCodeType="Trace" value="if (this.semaphorDebug)&lt;br/&gt;    this.rc.logWarning(&quot;&quot;&quot;$$etname - Regel $$Rule / $$Rules (Trace) : event = $eventProcedure ; json = ${event.asJsonValue().toString()}&quot;&quot;&quot;)"/>
</LFET>
